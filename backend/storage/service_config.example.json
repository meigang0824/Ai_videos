{
  "llm": {
    "enabled": true,
    "provider": "openai_chat",
    "url": "https://coding.dashscope.aliyuncs.com/v1/chat/completions",
    "apiKey": "",
    "model": "qwen3.6-plus",
    "timeout": 120,
    "headerName": "Authorization",
    "headerPrefix": "Bearer ",
    "textPath": "choices.0.message.content"
  },
  "asr": {
    "enabled": true,
    "provider": "multipart",
    "url": "http://192.168.1.9:8000/v1/audio/transcribe",
    "apiKey": "",
    "model": "base",
    "timeout": 300,
    "headerName": "Authorization",
    "headerPrefix": "Bearer ",
    "fileField": "file",
    "videoField": "video",
    "urlField": "url",
    "urlTranscribeUrl": "",
    "videoTranscribeUrl": "",
    "language": "zh",
    "textPath": "text",
    "segmentsPath": "segments"
  },
  "tts": {
    "enabled": true,
    "provider": "json",
    "url": "http://192.168.1.9:8000/v1/tts/synthesize",
    "speakerUrl": "http://192.168.1.9:8000/v1/tts/speakers",
    "cloneUrl": "http://192.168.1.9:8000/v1/tts/clone",
    "apiKey": "",
    "model": "",
    "timeout": 240,
    "headerName": "Authorization",
    "headerPrefix": "Bearer ",
    "textField": "text",
    "voiceField": "speaker",
    "speedField": "speed",
    "outputMode": "binary",
    "audioPath": "audio_url",
    "base64Path": "audio",
    "useMultipart": false,
    "promptTextField": "prompt_text",
    "promptAudioField": "prompt_audio"
  },
  "videoCompose": {
    "enabled": true,
    "provider": "json",
    "url": "http://192.168.1.9:8000/v1/video/compose",
    "apiKey": "",
    "timeout": 900,
    "headerName": "Authorization",
    "headerPrefix": "Bearer ",
    "outputMode": "json_url",
    "videoPath": "video_url",
    "base64Path": "video"
  }
